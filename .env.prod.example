# ── Domain & IP ────────────────────────────────────────────────
DOMAIN=app.medliver.mn
SERVER_IP=109.123.232.200

# ── MongoDB credentials ────────────────────────────────────────
# Аюулгүй нууц үг үүсгэх: openssl rand -base64 24
MONGO_USER=hisadmin
MONGO_PASS=CHANGE_ME_STRONG_PASSWORD

# ── JWT ────────────────────────────────────────────────────────
# Санамсаргүй дараалал үүсгэх: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# ── Seed (анхны admin бүртгэл) ────────────────────────────────
SEED_ADMIN_EMAIL=admin@medliver.mn
SEED_ADMIN_PASSWORD=Admin@2025!
SEED_ADMIN_NAME=Системийн Админ
