# Backend (apps/api)
API_PORT=4000

# MongoDB connection — choose ONE of:
# (a) Local MongoDB Community Server (no auth)
MONGO_URI=mongodb://localhost:27017/hospital_his
# (b) Docker container (docker-compose.yml)
# MONGO_URI=mongodb://hisroot:hisrootpass@localhost:27017/hospital_his?authSource=admin
# (c) MongoDB Atlas
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/hospital_his?retryWrites=true&w=majority
JWT_SECRET=change-me-in-production-very-long-random-string
JWT_EXPIRES_IN=12h
CORS_ORIGIN=http://localhost:3000

# Default admin (used by seed script)
SEED_ADMIN_EMAIL=admin@hospital.mn
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Системийн админ

# Frontend (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
